package edu.ucalgary.oop;

public class CulturalRequirementLoader {
    private Map<String, Set<String>> options;

    public CulturalRequirementLoader() {
        load();
    }

    private void load() {
        try (ObjectInputStream ois = new ObjectInputStream(
                getClass().getClassLoader()
                .getResourceAsStream("available_requirements.ser"))) {

            CulturalOptions data = (CulturalOptions) ois.readObject();
            this.options = data.getAccommodations();

        } catch (Exception e) {
            throw new RuntimeException("Could not load cultural requirements file");
        }
    }

    public Map<String, Set<String>> getOptions() {
        return options;
    }
}